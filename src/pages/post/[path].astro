---
import Default from "@layouts/default.astro";
import { getFormattedDate } from "@utils/index";

export async function getStaticPaths() {
  const posts = (await Astro.glob("./../../../posts/**/*.{md,mdx}")).filter(
    (post) => !post.frontmatter.draft
  );

  const paths = [] as any[];

  posts.forEach((post) => {
    paths.push({
      params: { path: post.frontmatter.path },
      props: { post: post },
    });
  });
  return paths;
}

const { post } = Astro.props;
const { Content } = post;
---

<Default
  title={post.frontmatter.title}
  description={post.frontmatter.excerpt}
  image={post.frontmatter.image}
>
  <div class="page">
    <section style="padding-top: 72px; padding-bottom: 80px;">
      <div class="wrap" style="max-width: 780px;">

        <!-- Back link -->
        <a href="/blog/" style="display: inline-flex; align-items: center; gap: 8px; font-size: 12px; color: var(--fg-mute); margin-bottom: 40px; transition: color 0.15s;"
          onmouseover="this.style.color='var(--accent)'"
          onmouseout="this.style.color='var(--fg-mute)'"
        >
          ← back to writing
        </a>

        <!-- Post header -->
        <div style="margin-bottom: 48px;">
          <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px;">
            {post.frontmatter.tags?.map((tag: string) => (
              <a
                href={`/tag/${tag}`}
                style="font-size: 11px; color: var(--accent); padding: 4px 10px; border: 1px solid rgba(37,99,235,0.3); border-radius: 3px; background: var(--accent-glow); transition: background 0.15s;"
              >
                #{tag}
              </a>
            ))}
          </div>
          <h1 style="font-size: clamp(28px, 4vw, 48px); font-weight: 700; letter-spacing: -0.03em; line-height: 1.1; color: var(--fg); margin-bottom: 20px;">
            {post.frontmatter.title}
          </h1>
          <div style="display: flex; align-items: center; gap: 20px; font-size: 12px; color: var(--fg-mute);">
            <span>{getFormattedDate(post.frontmatter.date)}</span>
            <span style="width: 1px; height: 12px; background: var(--line);"></span>
            <span>Istiaq Nirab</span>
          </div>
        </div>

        <!-- Divider -->
        <div style="height: 1px; background: var(--line); margin-bottom: 48px;"></div>

        <!-- Content -->
        <div class="prose-terminal">
          <Content />
        </div>

        <!-- Author bio -->
        <div style="margin-top: 64px; border-top: 1px solid var(--line); padding-top: 32px;">
          <div style="border: 1px solid var(--line); background: var(--bg-2); padding: 24px; display: flex; gap: 20px; align-items: flex-start;">
            <div style="flex-shrink: 0;">
              <div style="width: 56px; height: 56px; border: 1px solid var(--line); overflow: hidden; border-radius: 3px;">
                <img src="/me-classic.jpeg" alt="Istiaq Nirab" style="width: 100%; height: 100%; object-fit: cover;" />
              </div>
            </div>
            <div>
              <div style="font-weight: 600; font-size: 15px; color: var(--fg); margin-bottom: 4px;">Istiaq Nirab</div>
              <div style="font-size: 11px; color: var(--fg-mute); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 10px;">WordPress Plugin Dev · AI Engineer</div>
              <p style="font-size: 13px; color: var(--fg-dim); line-height: 1.6; margin-bottom: 12px;">
                Five-plus years shipping WooCommerce plugins used by thousands of stores. Currently building AI-powered products with LLMs, RAG, and Python.
              </p>
              <a href="https://twitter.com/Ok9xNirab" target="_blank" rel="noreferrer"
                style="font-size: 12px; color: var(--accent);">
                @Ok9xNirab →
              </a>
            </div>
          </div>
        </div>

      </div>
    </section>
  </div>
</Default>

---
const pathname = new URL(Astro.request.url).pathname;

const pages = [
  { label: "home",    href: "/",         key: "1" },
  { label: "plugins", href: "/plugins/", key: "2" },
  { label: "blog",    href: "/blog/",    key: "3" },
  { label: "contact", href: "/contact/", key: "4" },
];

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href.replace(/\/$/, ""));
}
---

<header class="topbar">
  <div class="wrap topbar-inner">
    <a href="/" class="brand">
      <span class="brand-dot"></span>
      <span class="brand-path">
        <span class="brand-slash">~/</span><span class="brand-name">istiaq</span>
      </span>
      <span class="brand-caret">▊</span>
    </a>

    <nav class="primary">
      {pages.map((p) => (
        <a
          href={p.href}
          class={isActive(p.href) ? "active" : ""}
        >
          <span class="nav-key">{p.key}</span>{p.label}
        </a>
      ))}
    </nav>

    <div class="topbar-right">
      <span class="status-pill">
        <span class="led"></span>
        available
      </span>
    </div>
  </div>
</header>
